# Example environment variables (DO NOT put real secrets here)

# アプリからの接続用
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=no-verify"

# Prismaのマイグレーション（db pushなど）用
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=no-verify"

# JWT署名用シークレット
JWT_SECRET="REPLACE_WITH_STRONG_SECRET"

